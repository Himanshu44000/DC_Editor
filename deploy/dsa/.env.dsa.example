# Copy to deploy/dsa/.env.dsa and fill real values.
# Keep secrets out of git.

PORT=4000

# Required queue/worker flags
USE_EXECUTION_QUEUE=true
USE_DOCKER=true
EXECUTION_WORKER_CONCURRENCY=4
DSA_EXECUTION_CPUS=1.5
DSA_EXECUTION_MEMORY=1024m
DSA_EXECUTION_TIMEOUT_MS=20000

# API/worker infrastructure
DATABASE_URL=postgresql://dce:dce_password_change_me@postgres:5432/dce
REDIS_URL=redis://redis:6379

# Auth (required for protected API routes)
# JWT Authentication Secrets (Change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d
BCRYPT_ROUNDS=10

# Storage and realtime integrations (if used)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional oauth/AI values
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=
FRONTEND_BASE_URL=
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
